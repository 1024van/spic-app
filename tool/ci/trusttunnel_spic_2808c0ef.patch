+
+    companion object {
+        private const val LOG_TAG = "VPN_PLUGIN"
+        private const val ACTION_START = "Start"
+        private const val ACTION_STOP = "Stop"
+        const val ACTION_OPEN_MAIN = "com.example.spic.action.OPEN_MAIN"
+        const val ACTION_OPEN_DIAGNOSTICS = "com.example.spic.action.OPEN_DIAGNOSTICS"
+        const val ACTION_OPEN_FROM_TILE = "com.example.spic.action.OPEN_FROM_TILE"
+        private const val PARAM_CONFIG = "Config Extra"
+        private const val PARAM_SERVER_NAME = "Server Name"
+        const val PARAM_APP_ACTION = "spic_action"
+        private const val NOTIFICATION_ID = 1
+
+        private val SYNC = Any()
+        private val IPV4_NON_ROUTABLE = listOf("0.0.0.0/8", "224.0.0.0/3")
+        private val ADGUARD_DNS_SERVERS = listOf(
+            "46.243.231.30",
+            "46.243.231.31",
+            "2a10:50c0::2:ff",
+            "2a10:50c0::1:ff",
+        )
+        private val FAKE_DNS_SERVER = listOf("198.18.53.53")
+
+        private var currentStartId: Int = -1
+        private var vpnClient: VpnClient? = null
+        private var activeTun: ParcelFileDescriptor? = null
+        private var configStorage: VpnConfigStorage? = null
+        private var connectivityManager: ConnectivityManager? = null
+        private var networkRequest: NetworkRequest? = null
+        private var networkCallback: NetworkUtils.Companion.NetworkCollector? = null
+
+        fun start(context: Context, config: String, serverName: String) {
+            start(context, ACTION_START, config, serverName)
+        }
+
+        fun stop(context: Context) {
+            getConfigStorage(context).clear()
+            start(context, ACTION_STOP, null, null)
+        }
+
+        fun startNetworkManager(context: Context) {
+            if (networkCallback != null) {
+                return
+            }
+
+            connectivityManager = context.getSystemService(Context.CONNECTIVITY_SERVICE) as ConnectivityManager
+            networkRequest = NetworkRequest.Builder()
+                .addCapability(12)
+                .addCapability(15)
+                .addTransportType(3)
+                .addTransportType(1)
+                .addTransportType(0)
+                .addTransportType(2)
+                .build()
+            networkCallback = NetworkUtils.Companion.NetworkCollector()
+
+            connectivityManager?.registerNetworkCallback(
+                networkRequest ?: return,
+                networkCallback ?: return,
+            )
+        }
+
+        fun isPrepared(context: Context): Boolean {
+            return try {
+                prepare(context) == null
+            } catch (t: Throwable) {
+                Log.e(LOG_TAG, "Error while checking VPN service preparation", t)
+                false
+            }
+        }
+
+        private fun start(context: Context, action: String, config: String?, serverName: String?) {
+            if (!isPrepared(context)) {
+                Log.w(LOG_TAG, "VPN is not prepared, can't manipulate the service")
+                return
+            }
+
+            try {
+                val intent = Intent(context, SplitTunnelVpnService::class.java).setAction(action)
+                if (config != null) {
+                    getConfigStorage(context).save(config)
+                    intent.putExtra(PARAM_CONFIG, config)
+                }
+                if (serverName != null) {
+                    intent.putExtra(PARAM_SERVER_NAME, serverName)
+                }
+                context.startForegroundService(intent)
+            } catch (t: Throwable) {
+                Log.e(LOG_TAG, "Error occurred while service starting", t)
+            }
+        }
+
+        private fun getConfigStorage(context: Context): VpnConfigStorage {
+            return configStorage ?: VpnConfigStorage(context).also { configStorage = it }
+        }
+    }
+}
