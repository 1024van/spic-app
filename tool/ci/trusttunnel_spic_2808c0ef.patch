+            .build()
+    }
+
+    private fun notificationProfileFrom(intent: Intent): NotificationProfile {
+        val config = intent.getStringExtra(PARAM_CONFIG).orEmpty()
+        val serverName = intent.getStringExtra(PARAM_SERVER_NAME)
+            ?.takeIf { it.isNotBlank() }
+            ?: "SPIC"
+        val hostname = Regex("hostname\\s*=\\s*\"([^\"]*)\"")
+            .find(config)
+            ?.groupValues
+            ?.getOrNull(1)
+            ?.lowercase()
+            .orEmpty()
+        val addresses = Regex("""addresses\s*=\s*\[(.*?)\]""", RegexOption.DOT_MATCHES_ALL)
+            .find(config)
+            ?.groupValues
+            ?.getOrNull(1)
+            .orEmpty()
+            .lowercase()
+        val dnsUpstreams = Regex("""dns_upstreams\s*=\s*\[(.*?)\]""", RegexOption.DOT_MATCHES_ALL)
+            .find(config)
+            ?.groupValues
+            ?.getOrNull(1)
+            .orEmpty()
+        val antiDpi = Regex("""anti_dpi\s*=\s*(true|false)""", RegexOption.IGNORE_CASE)
+            .find(config)
+            ?.groupValues
+            ?.getOrNull(1)
+            ?.equals("true", ignoreCase = true)
+            ?: false
+        val fallbackProtocol = Regex("upstream_fallback_protocol\\s*=\\s*\"([^\"]*)\"")
+            .find(config)
+            ?.groupValues
+            ?.getOrNull(1)
+            .orEmpty()
+        val trustedRoute = hostname == "stop2virus.xyz" ||
+            addresses.contains("185.236.24.249")
+
+        return NotificationProfile(
+            serverName = serverName,
+            externalRoute = !trustedRoute,
+            dnsProtected = dnsUpstreams.isNotBlank(),
+            secureRoute = trustedRoute && (antiDpi || fallbackProtocol.isNotBlank()),
+        )
+    }
