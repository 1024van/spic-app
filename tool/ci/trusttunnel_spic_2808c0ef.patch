+package com.adguard.trusttunnel.vpn_plugin
+
+import android.app.PendingIntent
+import android.content.ComponentName
+import android.content.Context
+import android.content.Intent
+import android.os.Build
+import android.service.quicksettings.Tile
+import android.service.quicksettings.TileService
+import androidx.annotation.RequiresApi
+
+@RequiresApi(Build.VERSION_CODES.N)
+class SpicQuickSettingsTileService : TileService() {
+    override fun onStartListening() {
+        super.onStartListening()
+        updateTile()
+    }
+
+    override fun onClick() {
+        super.onClick()
+
+        if (isVpnActive()) {
+            SplitTunnelVpnService.stop(applicationContext)
+            updateTile()
+            return
+        }
+
+        openSpic()
+    }
+
+    private fun updateTile() {
+        val tile = qsTile ?: return
+        val active = isVpnActive()
+        tile.label = "SPIC"
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.Q) {
+            tile.subtitle = if (active) "Protected" else "Tap to open"
+        }
+        tile.state = if (active) Tile.STATE_ACTIVE else Tile.STATE_INACTIVE
+        tile.updateTile()
+    }
+
+    private fun openSpic() {
+        val intent = packageManager.getLaunchIntentForPackage(packageName)
+            ?: Intent()
+        intent.action = SplitTunnelVpnService.ACTION_OPEN_FROM_TILE
+        intent.putExtra(
+            SplitTunnelVpnService.PARAM_APP_ACTION,
+            SplitTunnelVpnService.ACTION_OPEN_FROM_TILE,
+        )
+        intent.addFlags(Intent.FLAG_ACTIVITY_CLEAR_TOP or Intent.FLAG_ACTIVITY_SINGLE_TOP)
+
+        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.UPSIDE_DOWN_CAKE) {
+            startActivityAndCollapse(
+                PendingIntent.getActivity(
+                    this,
+                    REQUEST_OPEN_SPIC,
+                    intent,
+                    pendingIntentFlags(),
+                ),
+            )
+        } else {
+            @Suppress("DEPRECATION")
+            startActivityAndCollapse(intent)
+        }
+    }
+
+    private fun isVpnActive(): Boolean {
+        return SplitTunnelRuntimeNotifier.getCurrentState() != VpnManagerState.DISCONNECTED
+    }
+
+    private fun pendingIntentFlags(): Int {
+        return if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.M) {
+            PendingIntent.FLAG_UPDATE_CURRENT or PendingIntent.FLAG_IMMUTABLE
+        } else {
+            PendingIntent.FLAG_UPDATE_CURRENT
+        }
+    }
+
+    companion object {
+        private const val REQUEST_OPEN_SPIC = 2101
+
+        fun requestTileRefresh(context: Context) {
+            if (Build.VERSION.SDK_INT < Build.VERSION_CODES.N) {
+                return
+            }
+
+            requestListeningState(
+                context,
+                ComponentName(context, SpicQuickSettingsTileService::class.java),
+            )
+        }
+    }
+}
