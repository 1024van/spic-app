+                tun.includedRoutes,
+                tun.excludedRoutes + IPV4_NON_ROUTABLE,
+            ) ?: throw IllegalStateException("Failed to process routes")
+
+            for (route in routes) {
+                val pair = NetworkUtils.Companion.convertCidrToAddressPrefixPair(route)
+                    ?: throw IllegalArgumentException("Wrong syntax for included_routes")
+                builder.addRoute(pair.first, pair.second)
+            }
+
+            builder.establish()
+        } catch (t: Throwable) {
+            Log.e(LOG_TAG, "Error while building the TUN interface", t)
+            null
+        }
+    }
