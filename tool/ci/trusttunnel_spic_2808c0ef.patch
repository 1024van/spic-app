+
+class SplitTunnelVpnService : android.net.VpnService(), VpnClientListener {
+    private enum class State {
+        Stopped,
+        Started,
+    }
+
+    private var state = State.Stopped
+    private val singleThread: ScheduledExecutorService = Executors.newSingleThreadScheduledExecutor()
+    private var certificateVerificator: CertificateVerificator? = null
+    private var activeNotificationProfile: NotificationProfile = NotificationProfile()
+
+    override fun onStartCommand(intent: Intent?, flags: Int, startId: Int): Int {
+        synchronized(SYNC) {
+            if (intent == null) {
+                stopSelf()
+                return START_NOT_STICKY
+            }
+
+            activeNotificationProfile = notificationProfileFrom(intent)
+            val notification = createNotification(
+                applicationContext,
+                activeNotificationProfile,
+                VpnManagerState.CONNECTING,
+            )
+            if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.Q) {
+                startForeground(
+                    NOTIFICATION_ID,
+                    notification,
+                    ServiceInfo.FOREGROUND_SERVICE_TYPE_SYSTEM_EXEMPTED,
+                )
+            } else {
+                startForeground(NOTIFICATION_ID, notification)
+            }
+
+            singleThread.execute {
+                currentStartId = startId
+                try {
