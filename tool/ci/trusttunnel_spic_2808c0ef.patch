@@ -0,0 +1,43 @@
+package com.adguard.trusttunnel.vpn_plugin
+
+import com.adguard.trusttunnel.AppNotifier
+import java.util.ArrayDeque
+import java.util.concurrent.CopyOnWriteArraySet
+
+object SplitTunnelRuntimeNotifier {
+    private const val MAX_LOGS = 200
+    private val listeners = CopyOnWriteArraySet<AppNotifier>()
+    private val recentLogs = ArrayDeque<String>()
+
+    @Volatile
+    private var currentState: VpnManagerState = VpnManagerState.DISCONNECTED
+
+    fun addListener(listener: AppNotifier) {
+        listeners.add(listener)
+        listener.onStateChanged(currentState.raw)
+        synchronized(recentLogs) {
+            recentLogs.forEach(listener::onConnectionInfo)
+        }
+    }
+
+    fun removeListener(listener: AppNotifier) {
+        listeners.remove(listener)
+    }
+
+    fun onStateChanged(state: Int) {
+        currentState = VpnManagerState.ofRaw(state) ?: VpnManagerState.DISCONNECTED
+        listeners.forEach { it.onStateChanged(currentState.raw) }
+    }
+
+    fun onConnectionInfo(info: String) {
+        synchronized(recentLogs) {
+            if (recentLogs.size >= MAX_LOGS) {
+                recentLogs.removeFirst()
+            }
+            recentLogs.addLast(info)
+        }
+        listeners.forEach { it.onConnectionInfo(info) }
+    }
+
+    fun getCurrentState(): VpnManagerState = currentState
+}
