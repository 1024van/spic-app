+package com.adguard.trusttunnel.vpn_plugin
+
+import android.content.Context
+
+object SplitTunnelStore {
+    private const val PREFS_NAME = "split_tunnel_store"
+    private const val KEY_BYPASSED_PACKAGES = "bypassed_packages"
+
+    fun load(context: Context): List<String> {
+        val values = context
+            .getSharedPreferences(PREFS_NAME, Context.MODE_PRIVATE)
+            .getStringSet(KEY_BYPASSED_PACKAGES, emptySet())
+            .orEmpty()
+            .toSet()
+            .filter { it.isNotBlank() }
+            .toMutableList()
+
+        values.sort()
+        return values
+    }
+
+    fun save(context: Context, packageNames: List<String>) {
+        val sanitized = packageNames
+            .map { it.trim() }
+            .filter { it.isNotEmpty() }
+            .toSet()
+
+        context
+            .getSharedPreferences(PREFS_NAME, Context.MODE_PRIVATE)
+            .edit()
+            .putStringSet(KEY_BYPASSED_PACKAGES, sanitized)
+            .commit()
+    }
+}
