+    private fun createTunInterface(config: VpnServiceConfig): ParcelFileDescriptor? {
+        return try {
+            val tun = config.listener.tun
+            val builder = Builder()
+                .setSession("Trust Tunnel")
+                .setMtu(tun.mtuSize.toInt())
+                .addAddress("172.20.2.13", 32)
+                .addAddress("fdfd:29::2", 64)
+
+            val disallowedPackages = buildSet {
+                add(packageName)
+                addAll(SplitTunnelStore.load(applicationContext))
+            }
+            Log.i(
+                LOG_TAG,
+                "Applying split tunnel bypass packages: ${disallowedPackages.joinToString()}",
+            )
+
+            for (packageName in disallowedPackages) {
+                try {
+                    builder.addDisallowedApplication(packageName)
+                } catch (t: Throwable) {
+                    Log.w(LOG_TAG, "Failed to disallow package $packageName", t)
+                }
+            }
+
+            val dnsServers = if (config.endpoint.dnsUpstreams.isEmpty()) {
+                ADGUARD_DNS_SERVERS
+            } else {
+                FAKE_DNS_SERVER
+            }
+            dnsServers.forEach(builder::addDnsServer)
