+        val stateLabel = when (state) {
+            VpnManagerState.CONNECTING -> "Preparing protection"
+            VpnManagerState.CONNECTED -> "$routeLabel - $dnsLabel"
+            VpnManagerState.WAITING_FOR_RECOVERY,
+            VpnManagerState.RECOVERING,
+            VpnManagerState.WAITING_FOR_NETWORK -> "Reconnecting securely - $dnsLabel"
+            VpnManagerState.DISCONNECTED -> "Protection stopped"
