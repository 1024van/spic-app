diff --git a/lib/data/datasources/in_memory_routing_datasource.dart b/lib/data/datasources/in_memory_routing_datasource.dart
new file mode 100644
index 0000000..477ad27
--- /dev/null
+++ b/lib/data/datasources/in_memory_routing_datasource.dart
@@ -0,0 +1,109 @@
+import 'package:trusttunnel/data/datasources/routing_datasource.dart';
+import 'package:trusttunnel/data/model/routing_mode.dart';
+import 'package:trusttunnel/data/model/routing_profile.dart';
+import 'package:trusttunnel/data/model/routing_profile_data.dart';
+import 'package:trusttunnel/shared_constants.dart';
+
+class InMemoryRoutingDataSource implements RoutingDataSource {
+  final List<RoutingProfile> _profiles = [
+    RoutingProfile(
+      id: kDefaultRoutingProfileId,
+      data: const RoutingProfileData(
+        name: 'Default',
+        defaultMode: RoutingMode.vpn,
+        bypassRules: [],
+        vpnRules: [],
+      ),
+    ),
+  ];
+
+  @override
+  Future<RoutingProfile> addNewProfile(RoutingProfileData request) async {
+    final profile = RoutingProfile(
+      id: _nextProfileId(),
+      data: request,
+    );
+
+    _profiles.add(profile);
+    return profile;
+  }
+
+  @override
+  Future<RoutingProfile> getProfileById({required String id}) async =>
+      _profiles.firstWhere((profile) => profile.id == id);
+
+  @override
+  Future<List<RoutingProfile>> getAllProfiles() async => List.unmodifiable(_profiles);
+
+  @override
+  Future<void> setDefaultRoutingMode({
+    required String id,
+    required RoutingMode mode,
+  }) async {
+    final index = _profiles.indexWhere((profile) => profile.id == id);
+    if (index == -1) return;
+
+    final old = _profiles[index];
+    _profiles[index] = old.copyWith(
+      data: old.data.copyWith(defaultMode: mode),
+    );
+  }
+
+  @override
+  Future<void> setProfileName({
+    required String id,
+    required String name,
+  }) async {
+    final index = _profiles.indexWhere((profile) => profile.id == id);
+    if (index == -1) return;
+
+    final old = _profiles[index];
+    _profiles[index] = old.copyWith(
+      data: old.data.copyWith(name: name),
+    );
+  }
+
+  @override
+  Future<void> setRules({
+    required String id,
+    required RoutingMode mode,
+    required List<String> rules,
+  }) async {
+    final index = _profiles.indexWhere((profile) => profile.id == id);
+    if (index == -1) return;
+
+    final old = _profiles[index];
+    _profiles[index] = old.copyWith(
+      data: switch (mode) {
+        RoutingMode.bypass => old.data.copyWith(bypassRules: rules),
+        RoutingMode.vpn => old.data.copyWith(vpnRules: rules),
+      },
+    );
+  }
+
+  @override
+  Future<void> removeAllRules({required String id}) async {
+    final index = _profiles.indexWhere((profile) => profile.id == id);
+    if (index == -1) return;
+
+    final old = _profiles[index];
+    _profiles[index] = old.copyWith(
+      data: old.data.copyWith(
+        bypassRules: const [],
+        vpnRules: const [],
+      ),
+    );
+  }
+
+  @override
+  Future<void> deleteProfile({required String id}) async {
+    _profiles.removeWhere((profile) => profile.id == id);
+  }
+
+  String _nextProfileId() {
+    final maxId = _profiles
+        .map((profile) => int.tryParse(profile.id) ?? 0)
+        .fold<int>(0, (previous, current) => current > previous ? current : previous);
+    return '${maxId + 1}';
+  }
+}
diff --git a/lib/data/datasources/in_memory_server_datasource_fin.dart b/lib/data/datasources/in_memory_server_datasource_fin.dart
new file mode 100644
index 0000000..a0cca23
--- /dev/null
+++ b/lib/data/datasources/in_memory_server_datasource_fin.dart
@@ -0,0 +1,316 @@
+import 'dart:convert';
+import 'dart:io';
+
+import 'package:trusttunnel/data/datasources/server_datasource.dart';
+import 'package:trusttunnel/data/model/server.dart';
+import 'package:trusttunnel/data/model/server_data.dart';
+import 'package:trusttunnel/data/model/vpn_protocol.dart';
+import 'package:trusttunnel/shared_constants.dart';
+import 'package:vpn_plugin/deep_link_manager.dart';
+import 'package:vpn_plugin/models/upstream_protocol.dart';
+
+class InMemoryServerDataSource implements ServerDataSource {
+  final List<Server> _servers = [];
+  final DeepLinkManager _deepLinkManager = DeepLinkManagerImpl();
+
+  @override
+  Future<List<Server>> getAllServers() async => List.unmodifiable(_servers);
+
+  Future<Server?> getSelectedServer() async {
+    final servers = await getAllServers();
+
+    for (final server in servers) {
+      if (server.selected) {
+        return server;
+      }
+    }
+
+    return null;
+  }
+
+  @override
+  Future<void> setSelectedServerId({required String? id}) async {
+    for (var i = 0; i < _servers.length; i++) {
+      final server = _servers[i];
+      _servers[i] = server.copyWith(selected: server.id == id);
+    }
+  }
+
+  @override
+  Future<Server> addNewServer({required ServerData request}) async {
+    final server = Server(
+      id: _nextServerId(),
+      serverData: request,
+    );
+
+    _servers.add(server);
+    return server;
+  }
+
+  @override
+  Future<void> removeServer({required String serverId}) async {
+    _servers.removeWhere((server) => server.id == serverId);
+  }
+
+  @override
+  Future<void> setNewServer({
+    required String id,
+    required ServerData request,
+  }) async {
+    final index = _servers.indexWhere((server) => server.id == id);
+    if (index == -1) return;
+
+    _servers[index] = Server(
+      id: id,
+      serverData: request,
+      routingProfile: _servers[index].routingProfile,
+    );
+  }
+
+  @override
+  Future<Server> getServerById({required String id}) async => _servers.firstWhere((server) => server.id == id);
+
+  @override
+  Future<ServerData> getServerByBase64({
+    required String base64,
+    required String routingProfileId,
+  }) async {
+    final configuration = await _deepLinkManager.getConfigurationByBase64(base64: base64);
+
+    return ServerData.empty(
+      name: configuration.endpoint.name,
+      ipAddress: configuration.endpoint.addresses.first,
+      domain: configuration.endpoint.hostName,
+      username: configuration.endpoint.username,
+      password: configuration.endpoint.password,
+      vpnProtocol: configuration.endpoint.upStreamProtocol == UpStreamProtocol.http2
+          ? VpnProtocol.http2
+          : VpnProtocol.quic,
+      dnsServers: configuration.endpoint.dnsUpStreams,
+      routingProfileId: routingProfileId,
+      ipv6: configuration.endpoint.hasIpv6,
+      tlsPrefix: configuration.endpoint.clientRandom,
+      customSni: configuration.endpoint.customSni,
+    );
+  }
+
+  @override
+  Future<List<Server>> syncServersFromApi({required String? selectedServerId}) async {
+    final selectedServer = selectedServerId == null ? null : await _tryGetServerById(selectedServerId);
+
+    final client = HttpClient();
+    try {
+      final request = await client.getUrl(
+        Uri.parse('https://stop2virus.xyz/api/servers.json'),
+      );
+      final response = await request.close();
+      if (response.statusCode != 200) {
+        throw HttpException('Server API error: ${response.statusCode}');
+      }
+
+      final body = await response.transform(utf8.decoder).join();
+      final decoded = jsonDecode(body) as Map<String, dynamic>;
+      final serversJson = (decoded['servers'] as List?) ?? const [];
+      if (serversJson.isEmpty) {
+        return List.unmodifiable(_servers);
+      }
+
+      final syncedServers = <Server>[];
+      var nextId = int.parse(_nextServerId());
+      var selectedPreserved = false;
+
+      for (var index = 0; index < serversJson.length; index++) {
+        final serverJson = serversJson[index] as Map<String, dynamic>;
+        final host = '${serverJson['host'] ?? ''}'.trim();
+        final address = '${serverJson['address'] ?? ''}'.trim();
+        final username = '${serverJson['username'] ?? ''}'.trim();
+        final password = '${serverJson['password'] ?? ''}'.trim();
+        final name = '${serverJson['name'] ?? 'Server ${index + 1}'}'.trim();
+        final ipAddress = _extractIpAddress(host: host, address: address);
+        final countryCode = _countryCodeFromServerJson(
+          serverJson: serverJson,
+          name: name,
+          host: host,
+          ipAddress: ipAddress,
+        );
+        final matched = _findMatchingServer(
+          host: host,
+          address: address,
+        );
+        final id = matched?.id ?? '${nextId++}';
+        final effectiveUsername = username.isNotEmpty ? username : (matched?.username ?? '');
+        final effectivePassword = password.isNotEmpty ? password : (matched?.password ?? '');
+        final effectiveProtocol = _vpnProtocolFromServerJson(
+          serverJson,
+          fallback: matched?.vpnProtocol ?? VpnProtocol.http2,
+        );
+        final isSelected = selectedServerId == null ? index == 0 : id == selectedServerId;
+        if (isSelected) {
+          selectedPreserved = true;
+        }
+
+        syncedServers.add(
+          Server(
+            id: id,
+            serverData: ServerData.empty(
+              name: name.isEmpty ? 'Server ${index + 1}' : name,
+              ipAddress: ipAddress,
+              domain: host,
+              countryCode: countryCode,
+              username: effectiveUsername,
+              password: effectivePassword,
+              vpnProtocol: effectiveProtocol,
+              dnsServers: const ['1.1.1.1'],
+              routingProfileId: kDefaultRoutingProfileId,
+              selected: isSelected,
+            ),
+          ),
+        );
+      }
+
+      if (!selectedPreserved && selectedServer != null) {
+        syncedServers.insert(
+          0,
+          selectedServer.copyWith(selected: true),
+        );
+      }
+
+      _servers
+        ..clear()
+        ..addAll(syncedServers);
+
+      return List.unmodifiable(_servers);
+    } finally {
+      client.close(force: true);
+    }
+  }
+
+  String _nextServerId() {
+    final maxId = _servers
+        .map((server) => int.tryParse(server.id) ?? 0)
+        .fold<int>(0, (previous, value) => value > previous ? value : previous);
+    return '${maxId + 1}';
+  }
+
+  Server? _findMatchingServer({
+    required String host,
+    required String address,
+  }) {
+    final normalizedHost = host.trim().toLowerCase();
+    final normalizedAddress = address.trim().toLowerCase();
+    final normalizedAddressHost = normalizedAddress.split(':').first;
+
+    for (final server in _servers) {
+      final rawServerAddress = server.ipAddress.trim().toLowerCase();
+      final serverAddress = rawServerAddress.contains(':') ? rawServerAddress : '$rawServerAddress:443';
+      final rawServerHost = rawServerAddress.split(':').first;
+      final matchesHost = normalizedHost.isNotEmpty && server.domain.trim().toLowerCase() == normalizedHost;
+      final matchesAddress =
+          normalizedAddress.isNotEmpty &&
+          (serverAddress == normalizedAddress ||
+              rawServerAddress == normalizedAddress ||
+              rawServerHost == normalizedAddressHost);
+      if (matchesHost || matchesAddress) {
+        return server;
+      }
+    }
+
+    return null;
+  }
+
+  VpnProtocol _vpnProtocolFromServerJson(
+    Map<String, dynamic> serverJson, {
+    required VpnProtocol fallback,
+  }) {
+    final rawProtocol = '${serverJson['protocol'] ?? serverJson['vpnProtocol'] ?? ''}'.trim().toLowerCase();
+    return switch (rawProtocol) {
+      'http2' || 'http/2' || 'h2' => VpnProtocol.http2,
+      'quic' || 'http3' || 'http/3' || 'h3' => VpnProtocol.quic,
+      _ => fallback,
+    };
+  }
+
+  Future<Server?> _tryGetServerById(String id) async {
+    for (final server in _servers) {
+      if (server.id == id) {
+        return server;
+      }
+    }
+
+    return null;
+  }
+
+  String _extractIpAddress({
+    required String host,
+    required String address,
+  }) {
+    if (address.isNotEmpty) {
+      return address;
+    }
+
+    return host;
+  }
+
+  String? _countryCodeFromServerJson({
+    required Map<String, dynamic> serverJson,
+    required String name,
+    required String host,
+    required String ipAddress,
+  }) {
+    final directCode = _normalizeCountryCode(
+      serverJson['countryCode'] ??
+          serverJson['country_code'] ??
+          serverJson['country_iso'] ??
+          serverJson['isoCode'] ??
+          serverJson['country'] ??
+          serverJson['location'],
+    );
+    if (directCode != null) return directCode;
+
+    final countryText = [
+      serverJson['country'],
+      serverJson['location'],
+      serverJson['city'],
+      name,
+    ].whereType<Object>().join(' ').toLowerCase();
+
+    for (final entry in _countryNameCodes.entries) {
+      if (countryText.contains(entry.key)) return entry.value;
+    }
+
+    final hostKey = host.toLowerCase();
+    final ipKey = ipAddress.split(':').first.toLowerCase();
+    return _serverLocationCodes[hostKey] ?? _serverLocationCodes[ipKey];
+  }
+
+  String? _normalizeCountryCode(Object? value) {
+    final code = '$value'.trim().toUpperCase();
